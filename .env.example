# URL of the infoclimat-om-worker (basemap tile-proxy, labels overlay).
# When unset, those features are disabled.
# Local dev: VITE_OM_WORKER_URL=http://localhost:8080
VITE_OM_WORKER_URL=

# Bucket R2 des produits précalculés (anomalies, etc.). Sans valeur, le
# pseudo-domaine "Anomalie T°" n'apparaît pas dans le sélecteur.
VITE_MODELS_BUCKET_URL=

# Hôtes supplémentaires autorisés à atteindre le dev/preview server, séparés
# par des virgules (en plus de localhost, toujours permis). Utile pour tester
# depuis un mobile via un reverse proxy / tunnel. Un point initial = wildcard
# de sous-domaines. Aucun effet en prod (build statique).
# Ex : DEV_ALLOWED_HOSTS=.home.example.com,monapp.ngrok.app
DEV_ALLOWED_HOSTS=
